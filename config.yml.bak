providers:
- id: glm-local
  name: GLM-4.7-Flash (local, toolbox)
  type: llamacpp
  url: http://localhost:8080
  api_key: '****'
  active: false
- id: openrouter
  name: OpenRouter
  type: openai_compat
  url: https://openrouter.ai/api
  api_key: '****'
  active: true
model:
  provider_id: openrouter
  name: qwen/qwen3-next-80b-a3b-instruct:free
  temperature: 0.2
  context_size: null
  max_tokens: 4096
  inline_comments: true
gitlab:
  url: https://gitlab.fgdevelop.tech
  auth_type: token
  tls_verify: true
review_targets:
- type: group
  id: '127'
  branches:
    pattern: '*'
    protected_only: false
  auto_approve: false
  prompts:
    system: []
  author_allowlist: []
  skip_authors:
  - bot
  - ci-bot
  file_exclude: []
  review_cooldown_minutes: null
  max_files_per_review: null
  project_ids: []
queue:
  backend: memory
  max_concurrent: 3
  max_queue_size: 100
  valkey_url: redis://localhost:6379
  kafka_brokers: localhost:9092
  kafka_topic: glr.mr.events
  kafka_group_id: glr-reviewers
cache:
  backend: memory
  ttl: 3600
  valkey_url: redis://localhost:6379
prompts:
  system:
  - base
  - security
  - code_review
  - performance
  - style
notifications:
  enabled: false
  format: generic
  on_posted: true
  on_error: false
  on_skipped: false
review_cooldown_minutes: 2
max_files_per_review: 50
file_exclude:
- '*.lock'
- package-lock.json
- yarn.lock
- poetry.lock
- Cargo.lock
- vendor/**
- node_modules/**
- '*.min.js'
- '*.min.css'
- '*.generated.*'
- dist/**
- build/**
ui:
  enabled: true
  log_buffer_lines: 1000
server:
  host: 0.0.0.0
  port: 8000
  log_level: info
