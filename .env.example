# GitLab connection
GLR_GITLAB_URL=https://gitlab.example.com
GLR_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GLR_WEBHOOK_SECRET=your-webhook-secret-here

# LLM backend (ollama)
GLR_OLLAMA_URL=http://localhost:11434
GLR_OLLAMA_MODEL=qwen2.5-coder:32b
GLR_LLM_TIMEOUT=300
GLR_LLM_MAX_DIFF_CHARS=32000
GLR_LLM_TEMPERATURE=0.2

# Behaviour
GLR_DRY_RUN=false
GLR_MAX_FILES_PER_REVIEW=50
GLR_DIFF_CACHE_TTL=3600

# Server
GLR_HOST=0.0.0.0
GLR_PORT=8000
GLR_LOG_LEVEL=info
